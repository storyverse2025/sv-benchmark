{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Video Testcase Output Schema",
  "type": "object",
  "required": [
    "testcase_id",
    "core_intent",
    "duration_seconds",
    "story_logic",
    "shot_plan",
    "final_video_prompt",
    "negative_prompt",
    "coverage_notes",
    "active_dimensions"
  ],
  "properties": {
    "testcase_id": {"type": "string"},
    "core_intent": {"type": "string", "minLength": 10},
    "duration_seconds": {"type": "integer", "minimum": 10, "maximum": 15},
    "story_logic": {"type": "string", "minLength": 20},
    "shot_plan": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "shot_id",
          "time_range",
          "visual_goal",
          "what_happens",
          "camera_and_framing",
          "lighting_and_mood"
        ],
        "properties": {
          "shot_id": {"type": "integer", "minimum": 1},
          "time_range": {"type": "string"},
          "visual_goal": {"type": "string"},
          "what_happens": {"type": "string"},
          "camera_and_framing": {"type": "string"},
          "lighting_and_mood": {"type": "string"},
          "environment_and_color": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "final_video_prompt": {"type": "string", "minLength": 30},
    "negative_prompt": {"type": "string", "minLength": 10},
    "coverage_notes": {
      "type": "object",
      "required": ["must_show", "soft_interpretations", "tradeoffs"],
      "properties": {
        "must_show": {"type": "array", "items": {"type": "string"}},
        "soft_interpretations": {"type": "array", "items": {"type": "string"}},
        "tradeoffs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "active_dimensions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "style", "scenes", "subjects",
          "physical_state", "physical_rule", "texture", "opacity", "scale",
          "spatial_layout", "action", "emotion", "effect",
          "lighting_tone", "lighting_direction", "lighting_intensity",
          "color_saturation", "color_palette",
          "camera_angle", "camera_movement", "composition",
          "time_mode", "shot_size", "depth_of_field", "focal_length",
          "time_of_day", "weather", "transition"
        ]
      },
      "description": "EN field names of the 27 tag dimensions that were actually preserved in the final prompt. Omit any dimension whose tag was dropped or could not be meaningfully incorporated."
    }
  },
  "additionalProperties": false
}
